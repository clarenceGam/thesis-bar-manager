# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# backend
thesis-backend/

# dependencies
/node_modules
/.pnp
.pnp.js

# env files - never commit secrets
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
thesis-backend/.env

# production builds
/build
/dist
thesis-backend/dist

# uploads (user-generated files)
thesis-backend/uploads/*
!thesis-backend/uploads/.gitkeep

# testing
/coverage

# misc
.DS_Store
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Windsurf AI context docs
.windsurf/
